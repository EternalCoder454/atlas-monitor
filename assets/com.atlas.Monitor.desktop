[Desktop Entry]
Type=Application
Version=1.0
Name=Atlas Monitor
GenericName=System Monitor
Comment=Lightweight system monitor — CPU, memory, disk, network, GPU, processes and services
Exec=@BIN@
Icon=com.atlas.Monitor
Terminal=false
Categories=System;Monitor;GTK;
